{"surah":92,"ayat":[{"surah":92,"ayah":1,"key":"92:1","arabic_uthmani":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلَّيْلِ إِذَا يَغْشَىٰ","arabic_simple":"","english":"By the night enshrouding","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":2,"key":"92:2","arabic_uthmani":"وَٱلنَّهَارِ إِذَا تَجَلَّىٰ","arabic_simple":"","english":"And the day resplendent","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":3,"key":"92:3","arabic_uthmani":"وَمَا خَلَقَ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ","arabic_simple":"","english":"And Him Who hath created male and female,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":4,"key":"92:4","arabic_uthmani":"إِنَّ سَعْيَكُمْ لَشَتَّىٰ","arabic_simple":"","english":"Lo! your effort is dispersed (toward divers ends).","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":5,"key":"92:5","arabic_uthmani":"فَأَمَّا مَنْ أَعْطَىٰ وَٱتَّقَىٰ","arabic_simple":"","english":"As for him who giveth and is dutiful (toward Allah)","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":6,"key":"92:6","arabic_uthmani":"وَصَدَّقَ بِٱلْحُسْنَىٰ","arabic_simple":"","english":"And believeth in goodness;","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":7,"key":"92:7","arabic_uthmani":"فَسَنُيَسِّرُهُۥ لِلْيُسْرَىٰ","arabic_simple":"","english":"Surely We will ease his way unto the state of ease.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":8,"key":"92:8","arabic_uthmani":"وَأَمَّا مَنۢ بَخِلَ وَٱسْتَغْنَىٰ","arabic_simple":"","english":"But as for him who hoardeth and deemeth himself independent,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":9,"key":"92:9","arabic_uthmani":"وَكَذَّبَ بِٱلْحُسْنَىٰ","arabic_simple":"","english":"And disbelieveth in goodness;","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":10,"key":"92:10","arabic_uthmani":"فَسَنُيَسِّرُهُۥ لِلْعُسْرَىٰ","arabic_simple":"","english":"Surely We will ease his way unto adversity.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":11,"key":"92:11","arabic_uthmani":"وَمَا يُغْنِى عَنْهُ مَالُهُۥٓ إِذَا تَرَدَّىٰٓ","arabic_simple":"","english":"His riches will not save him when he perisheth.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":12,"key":"92:12","arabic_uthmani":"إِنَّ عَلَيْنَا لَلْهُدَىٰ","arabic_simple":"","english":"Lo! Ours it is (to give) the guidance","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":13,"key":"92:13","arabic_uthmani":"وَإِنَّ لَنَا لَلْـَٔاخِرَةَ وَٱلْأُولَىٰ","arabic_simple":"","english":"And lo! unto Us belong the latter portion and the former.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":14,"key":"92:14","arabic_uthmani":"فَأَنذَرْتُكُمْ نَارًا تَلَظَّىٰ","arabic_simple":"","english":"Therefor have I warned you of the flaming Fire","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":15,"key":"92:15","arabic_uthmani":"لَا يَصْلَىٰهَآ إِلَّا ٱلْأَشْقَى","arabic_simple":"","english":"Which only the most wretched must endure,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":16,"key":"92:16","arabic_uthmani":"ٱلَّذِى كَذَّبَ وَتَوَلَّىٰ","arabic_simple":"","english":"He who denieth and turneth away.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":17,"key":"92:17","arabic_uthmani":"وَسَيُجَنَّبُهَا ٱلْأَتْقَى","arabic_simple":"","english":"Far removed from it will be the righteous","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":18,"key":"92:18","arabic_uthmani":"ٱلَّذِى يُؤْتِى مَالَهُۥ يَتَزَكَّىٰ","arabic_simple":"","english":"Who giveth his wealth that he may grow (in goodness).","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":19,"key":"92:19","arabic_uthmani":"وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعْمَةٍ تُجْزَىٰٓ","arabic_simple":"","english":"And none hath with him any favour for reward,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":20,"key":"92:20","arabic_uthmani":"إِلَّا ٱبْتِغَآءَ وَجْهِ رَبِّهِ ٱلْأَعْلَىٰ","arabic_simple":"","english":"Except as seeking (to fulfil) the purpose of his Lord Most High.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":92,"ayah":21,"key":"92:21","arabic_uthmani":"وَلَسَوْفَ يَرْضَىٰ","arabic_simple":"","english":"He verily will be content.","juz":30,"hizb":0,"ruku":0,"page":0}]}