{"surah":96,"ayat":[{"surah":96,"ayah":1,"key":"96:1","arabic_uthmani":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ ٱقْرَأْ بِٱسْمِ رَبِّكَ ٱلَّذِى خَلَقَ","arabic_simple":"","english":"Read: In the name of thy Lord Who createth,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":96,"ayah":2,"key":"96:2","arabic_uthmani":"خَلَقَ ٱلْإِنسَـٰنَ مِنْ عَلَقٍ","arabic_simple":"","english":"Createth man from a clot.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":96,"ayah":3,"key":"96:3","arabic_uthmani":"ٱقْرَأْ وَرَبُّكَ ٱلْأَكْرَمُ","arabic_simple":"","english":"Read: And thy Lord is the Most Bounteous,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":96,"ayah":4,"key":"96:4","arabic_uthmani":"ٱلَّذِى عَلَّمَ بِٱلْقَلَمِ","arabic_simple":"","english":"Who teacheth by the pen,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":96,"ayah":5,"key":"96:5","arabic_uthmani":"عَلَّمَ ٱلْإِنسَـٰنَ مَا لَمْ يَعْلَمْ","arabic_simple":"","english":"Teacheth man that which he knew not.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":96,"ayah":6,"key":"96:6","arabic_uthmani":"كَلَّآ إِنَّ ٱلْإِنسَـٰنَ لَيَطْغَىٰٓ","arabic_simple":"","english":"Nay, but verily man is rebellious","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":96,"ayah":7,"key":"96:7","arabic_uthmani":"أَن رَّءَاهُ ٱسْتَغْنَىٰٓ","arabic_simple":"","english":"That he thinketh himself independent!","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":96,"ayah":8,"key":"96:8","arabic_uthmani":"إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجْعَىٰٓ","arabic_simple":"","english":"Lo! unto thy Lord is the return.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":96,"ayah":9,"key":"96:9","arabic_uthmani":"أَرَءَيْتَ ٱلَّذِى يَنْهَىٰ","arabic_simple":"","english":"Hast thou seen him who dissuadeth","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":96,"ayah":10,"key":"96:10","arabic_uthmani":"عَبْدًا إِذَا صَلَّىٰٓ","arabic_simple":"","english":"A slave when he prayeth?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":96,"ayah":11,"key":"96:11","arabic_uthmani":"أَرَءَيْتَ إِن كَانَ عَلَى ٱلْهُدَىٰٓ","arabic_simple":"","english":"Hast thou seen if he relieth on the guidance (of Allah)","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":96,"ayah":12,"key":"96:12","arabic_uthmani":"أَوْ أَمَرَ بِٱلتَّقْوَىٰٓ","arabic_simple":"","english":"Or enjoineth piety?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":96,"ayah":13,"key":"96:13","arabic_uthmani":"أَرَءَيْتَ إِن كَذَّبَ وَتَوَلَّىٰٓ","arabic_simple":"","english":"Hast thou seen if he denieth (Allah's guidance) and is froward?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":96,"ayah":14,"key":"96:14","arabic_uthmani":"أَلَمْ يَعْلَم بِأَنَّ ٱللَّهَ يَرَىٰ","arabic_simple":"","english":"Is he then unaware that Allah seeth?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":96,"ayah":15,"key":"96:15","arabic_uthmani":"كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًۢا بِٱلنَّاصِيَةِ","arabic_simple":"","english":"Nay, but if he cease not We will seize him by the forelock -","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":96,"ayah":16,"key":"96:16","arabic_uthmani":"نَاصِيَةٍ كَـٰذِبَةٍ خَاطِئَةٍ","arabic_simple":"","english":"The lying, sinful forelock -","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":96,"ayah":17,"key":"96:17","arabic_uthmani":"فَلْيَدْعُ نَادِيَهُۥ","arabic_simple":"","english":"Then let him call upon his henchmen!","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":96,"ayah":18,"key":"96:18","arabic_uthmani":"سَنَدْعُ ٱلزَّبَانِيَةَ","arabic_simple":"","english":"We will call the guards of hell.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":96,"ayah":19,"key":"96:19","arabic_uthmani":"كَلَّا لَا تُطِعْهُ وَٱسْجُدْ وَٱقْتَرِب ۩","arabic_simple":"","english":"Nay, Obey not thou him. But prostrate thyself, and draw near (unto Allah).","sajdah":true,"juz":30,"hizb":0,"ruku":0,"page":0}]}