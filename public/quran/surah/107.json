{"surah":107,"ayat":[{"surah":107,"ayah":1,"key":"107:1","arabic_uthmani":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ أَرَءَيْتَ ٱلَّذِى يُكَذِّبُ بِٱلدِّينِ","arabic_simple":"","english":"Hast thou observed him who belieth religion?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":107,"ayah":2,"key":"107:2","arabic_uthmani":"فَذَٰلِكَ ٱلَّذِى يَدُعُّ ٱلْيَتِيمَ","arabic_simple":"","english":"That is he who repelleth the orphan,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":107,"ayah":3,"key":"107:3","arabic_uthmani":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ","arabic_simple":"","english":"And urgeth not the feeding of the needy.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":107,"ayah":4,"key":"107:4","arabic_uthmani":"فَوَيْلٌ لِّلْمُصَلِّينَ","arabic_simple":"","english":"Ah, woe unto worshippers","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":107,"ayah":5,"key":"107:5","arabic_uthmani":"ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ","arabic_simple":"","english":"Who are heedless of their prayer;","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":107,"ayah":6,"key":"107:6","arabic_uthmani":"ٱلَّذِينَ هُمْ يُرَآءُونَ","arabic_simple":"","english":"Who would be seen (at worship)","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":107,"ayah":7,"key":"107:7","arabic_uthmani":"وَيَمْنَعُونَ ٱلْمَاعُونَ","arabic_simple":"","english":"Yet refuse small kindnesses!","juz":30,"hizb":0,"ruku":0,"page":0}]}