{"surah":86,"ayat":[{"surah":86,"ayah":1,"key":"86:1","arabic_uthmani":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ وَٱلطَّارِقِ","arabic_simple":"","english":"By the heaven and the Morning Star","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":86,"ayah":2,"key":"86:2","arabic_uthmani":"وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ","arabic_simple":"","english":"- Ah, what will tell thee what the Morning Star is!","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":86,"ayah":3,"key":"86:3","arabic_uthmani":"ٱلنَّجْمُ ٱلثَّاقِبُ","arabic_simple":"","english":"- The piercing Star!","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":86,"ayah":4,"key":"86:4","arabic_uthmani":"إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ","arabic_simple":"","english":"No human soul but hath a guardian over it.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":86,"ayah":5,"key":"86:5","arabic_uthmani":"فَلْيَنظُرِ ٱلْإِنسَـٰنُ مِمَّ خُلِقَ","arabic_simple":"","english":"So let man consider from what he is created.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":86,"ayah":6,"key":"86:6","arabic_uthmani":"خُلِقَ مِن مَّآءٍ دَافِقٍ","arabic_simple":"","english":"He is created from a gushing fluid","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":86,"ayah":7,"key":"86:7","arabic_uthmani":"يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ","arabic_simple":"","english":"That issued from between the loins and ribs.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":86,"ayah":8,"key":"86:8","arabic_uthmani":"إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌ","arabic_simple":"","english":"Lo! He verily is Able to return him (unto life)","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":86,"ayah":9,"key":"86:9","arabic_uthmani":"يَوْمَ تُبْلَى ٱلسَّرَآئِرُ","arabic_simple":"","english":"On the day when hidden thoughts shall be searched out.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":86,"ayah":10,"key":"86:10","arabic_uthmani":"فَمَا لَهُۥ مِن قُوَّةٍ وَلَا نَاصِرٍ","arabic_simple":"","english":"Then will he have no might nor any helper.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":86,"ayah":11,"key":"86:11","arabic_uthmani":"وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ","arabic_simple":"","english":"By the heaven which giveth the returning rain,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":86,"ayah":12,"key":"86:12","arabic_uthmani":"وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ","arabic_simple":"","english":"And the earth which splitteth (with the growth of trees and plants)","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":86,"ayah":13,"key":"86:13","arabic_uthmani":"إِنَّهُۥ لَقَوْلٌ فَصْلٌ","arabic_simple":"","english":"Lo! this (Qur'an) is a conclusive word,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":86,"ayah":14,"key":"86:14","arabic_uthmani":"وَمَا هُوَ بِٱلْهَزْلِ","arabic_simple":"","english":"It is no pleasantry.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":86,"ayah":15,"key":"86:15","arabic_uthmani":"إِنَّهُمْ يَكِيدُونَ كَيْدًا","arabic_simple":"","english":"Lo! they plot a plot (against thee, O Muhammad)","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":86,"ayah":16,"key":"86:16","arabic_uthmani":"وَأَكِيدُ كَيْدًا","arabic_simple":"","english":"And I plot a plot (against them).","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":86,"ayah":17,"key":"86:17","arabic_uthmani":"فَمَهِّلِ ٱلْكَـٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا","arabic_simple":"","english":"So give a respite to the disbelievers. Deal thou gently with them for a while.","juz":30,"hizb":0,"ruku":0,"page":0}]}