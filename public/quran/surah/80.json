{"surah":80,"ayat":[{"surah":80,"ayah":1,"key":"80:1","arabic_uthmani":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ عَبَسَ وَتَوَلَّىٰٓ","arabic_simple":"","english":"He frowned and turned away","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":2,"key":"80:2","arabic_uthmani":"أَن جَآءَهُ ٱلْأَعْمَىٰ","arabic_simple":"","english":"Because the blind man came unto him.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":3,"key":"80:3","arabic_uthmani":"وَمَا يُدْرِيكَ لَعَلَّهُۥ يَزَّكَّىٰٓ","arabic_simple":"","english":"What could inform thee but that he might grow (in grace)","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":4,"key":"80:4","arabic_uthmani":"أَوْ يَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكْرَىٰٓ","arabic_simple":"","english":"Or take heed and so the reminder might avail him?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":5,"key":"80:5","arabic_uthmani":"أَمَّا مَنِ ٱسْتَغْنَىٰ","arabic_simple":"","english":"As for him who thinketh himself independent,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":6,"key":"80:6","arabic_uthmani":"فَأَنتَ لَهُۥ تَصَدَّىٰ","arabic_simple":"","english":"Unto him thou payest regard.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":7,"key":"80:7","arabic_uthmani":"وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ","arabic_simple":"","english":"Yet it is not thy concern if he grow not (in grace).","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":8,"key":"80:8","arabic_uthmani":"وَأَمَّا مَن جَآءَكَ يَسْعَىٰ","arabic_simple":"","english":"But as for him who cometh unto thee with earnest purpose","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":9,"key":"80:9","arabic_uthmani":"وَهُوَ يَخْشَىٰ","arabic_simple":"","english":"And hath fear,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":10,"key":"80:10","arabic_uthmani":"فَأَنتَ عَنْهُ تَلَهَّىٰ","arabic_simple":"","english":"From him thou art distracted.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":11,"key":"80:11","arabic_uthmani":"كَلَّآ إِنَّهَا تَذْكِرَةٌ","arabic_simple":"","english":"Nay, but verily it is an Admonishment,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":12,"key":"80:12","arabic_uthmani":"فَمَن شَآءَ ذَكَرَهُۥ","arabic_simple":"","english":"So let whosoever will pay heed to it,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":13,"key":"80:13","arabic_uthmani":"فِى صُحُفٍ مُّكَرَّمَةٍ","arabic_simple":"","english":"On honoured leaves","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":14,"key":"80:14","arabic_uthmani":"مَّرْفُوعَةٍ مُّطَهَّرَةٍۭ","arabic_simple":"","english":"Exalted, purified,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":15,"key":"80:15","arabic_uthmani":"بِأَيْدِى سَفَرَةٍ","arabic_simple":"","english":"(Set down) by scribes","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":16,"key":"80:16","arabic_uthmani":"كِرَامٍۭ بَرَرَةٍ","arabic_simple":"","english":"Noble and righteous.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":17,"key":"80:17","arabic_uthmani":"قُتِلَ ٱلْإِنسَـٰنُ مَآ أَكْفَرَهُۥ","arabic_simple":"","english":"Man is (self-)destroyed: how ungrateful!","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":18,"key":"80:18","arabic_uthmani":"مِنْ أَىِّ شَىْءٍ خَلَقَهُۥ","arabic_simple":"","english":"From what thing doth He create him?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":19,"key":"80:19","arabic_uthmani":"مِن نُّطْفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ","arabic_simple":"","english":"From a drop of seed. He createth him and proportioneth him,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":20,"key":"80:20","arabic_uthmani":"ثُمَّ ٱلسَّبِيلَ يَسَّرَهُۥ","arabic_simple":"","english":"Then maketh the way easy for him,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":21,"key":"80:21","arabic_uthmani":"ثُمَّ أَمَاتَهُۥ فَأَقْبَرَهُۥ","arabic_simple":"","english":"Then causeth him to die, and burieth him;","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":22,"key":"80:22","arabic_uthmani":"ثُمَّ إِذَا شَآءَ أَنشَرَهُۥ","arabic_simple":"","english":"Then, when He will, He bringeth him again to life.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":23,"key":"80:23","arabic_uthmani":"كَلَّا لَمَّا يَقْضِ مَآ أَمَرَهُۥ","arabic_simple":"","english":"Nay, but (man) hath not done what He commanded him.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":24,"key":"80:24","arabic_uthmani":"فَلْيَنظُرِ ٱلْإِنسَـٰنُ إِلَىٰ طَعَامِهِۦٓ","arabic_simple":"","english":"Let man consider his food:","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":25,"key":"80:25","arabic_uthmani":"أَنَّا صَبَبْنَا ٱلْمَآءَ صَبًّا","arabic_simple":"","english":"How We pour water in showers","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":26,"key":"80:26","arabic_uthmani":"ثُمَّ شَقَقْنَا ٱلْأَرْضَ شَقًّا","arabic_simple":"","english":"Then split the earth in clefts","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":27,"key":"80:27","arabic_uthmani":"فَأَنۢبَتْنَا فِيهَا حَبًّا","arabic_simple":"","english":"And cause the grain to grow therein","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":28,"key":"80:28","arabic_uthmani":"وَعِنَبًا وَقَضْبًا","arabic_simple":"","english":"And grapes and green fodder","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":29,"key":"80:29","arabic_uthmani":"وَزَيْتُونًا وَنَخْلًا","arabic_simple":"","english":"And olive-trees and palm-trees","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":30,"key":"80:30","arabic_uthmani":"وَحَدَآئِقَ غُلْبًا","arabic_simple":"","english":"And garden-closes of thick foliage","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":31,"key":"80:31","arabic_uthmani":"وَفَـٰكِهَةً وَأَبًّا","arabic_simple":"","english":"And fruits and grasses:","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":32,"key":"80:32","arabic_uthmani":"مَّتَـٰعًا لَّكُمْ وَلِأَنْعَـٰمِكُمْ","arabic_simple":"","english":"Provision for you and your cattle.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":33,"key":"80:33","arabic_uthmani":"فَإِذَا جَآءَتِ ٱلصَّآخَّةُ","arabic_simple":"","english":"But when the Shout cometh","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":34,"key":"80:34","arabic_uthmani":"يَوْمَ يَفِرُّ ٱلْمَرْءُ مِنْ أَخِيهِ","arabic_simple":"","english":"On the day when a man fleeth from his brother","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":35,"key":"80:35","arabic_uthmani":"وَأُمِّهِۦ وَأَبِيهِ","arabic_simple":"","english":"And his mother and his father","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":36,"key":"80:36","arabic_uthmani":"وَصَـٰحِبَتِهِۦ وَبَنِيهِ","arabic_simple":"","english":"And his wife and his children,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":37,"key":"80:37","arabic_uthmani":"لِكُلِّ ٱمْرِئٍ مِّنْهُمْ يَوْمَئِذٍ شَأْنٌ يُغْنِيهِ","arabic_simple":"","english":"Every man that day will have concern enough to make him heedless (of others).","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":38,"key":"80:38","arabic_uthmani":"وُجُوهٌ يَوْمَئِذٍ مُّسْفِرَةٌ","arabic_simple":"","english":"On that day faces will be bright as dawn,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":39,"key":"80:39","arabic_uthmani":"ضَاحِكَةٌ مُّسْتَبْشِرَةٌ","arabic_simple":"","english":"Laughing, rejoicing at good news;","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":40,"key":"80:40","arabic_uthmani":"وَوُجُوهٌ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌ","arabic_simple":"","english":"And other faces, on that day, with dust upon them,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":41,"key":"80:41","arabic_uthmani":"تَرْهَقُهَا قَتَرَةٌ","arabic_simple":"","english":"Veiled in darkness,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":80,"ayah":42,"key":"80:42","arabic_uthmani":"أُو۟لَـٰٓئِكَ هُمُ ٱلْكَفَرَةُ ٱلْفَجَرَةُ","arabic_simple":"","english":"Those are the disbelievers, the wicked.","juz":30,"hizb":0,"ruku":0,"page":0}]}