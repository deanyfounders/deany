{"surah":100,"ayat":[{"surah":100,"ayah":1,"key":"100:1","arabic_uthmani":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلْعَـٰدِيَـٰتِ ضَبْحًا","arabic_simple":"","english":"By the snorting courses,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":100,"ayah":2,"key":"100:2","arabic_uthmani":"فَٱلْمُورِيَـٰتِ قَدْحًا","arabic_simple":"","english":"Striking sparks of fire","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":100,"ayah":3,"key":"100:3","arabic_uthmani":"فَٱلْمُغِيرَٰتِ صُبْحًا","arabic_simple":"","english":"And scouring to the raid at dawn,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":100,"ayah":4,"key":"100:4","arabic_uthmani":"فَأَثَرْنَ بِهِۦ نَقْعًا","arabic_simple":"","english":"Then, therewith, with their trail of dust,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":100,"ayah":5,"key":"100:5","arabic_uthmani":"فَوَسَطْنَ بِهِۦ جَمْعًا","arabic_simple":"","english":"Cleaving, as one, the centre (of the foe),","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":100,"ayah":6,"key":"100:6","arabic_uthmani":"إِنَّ ٱلْإِنسَـٰنَ لِرَبِّهِۦ لَكَنُودٌ","arabic_simple":"","english":"Lo! man is an ingrate unto his Lord","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":100,"ayah":7,"key":"100:7","arabic_uthmani":"وَإِنَّهُۥ عَلَىٰ ذَٰلِكَ لَشَهِيدٌ","arabic_simple":"","english":"And lo! he is a witness unto that;","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":100,"ayah":8,"key":"100:8","arabic_uthmani":"وَإِنَّهُۥ لِحُبِّ ٱلْخَيْرِ لَشَدِيدٌ","arabic_simple":"","english":"And lo! in the love of wealth he is violent.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":100,"ayah":9,"key":"100:9","arabic_uthmani":"۞ أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِى ٱلْقُبُورِ","arabic_simple":"","english":"Knoweth he not that, when the contents of the graves are poured forth","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":100,"ayah":10,"key":"100:10","arabic_uthmani":"وَحُصِّلَ مَا فِى ٱلصُّدُورِ","arabic_simple":"","english":"And the secrets of the breasts are made known,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":100,"ayah":11,"key":"100:11","arabic_uthmani":"إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍ لَّخَبِيرٌۢ","arabic_simple":"","english":"On that day will their Lord be perfectly informed concerning them.","juz":30,"hizb":0,"ruku":0,"page":0}]}