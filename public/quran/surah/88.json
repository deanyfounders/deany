{"surah":88,"ayat":[{"surah":88,"ayah":1,"key":"88:1","arabic_uthmani":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَـٰشِيَةِ","arabic_simple":"","english":"Hath there come unto thee tidings of the Overwhelming?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":2,"key":"88:2","arabic_uthmani":"وُجُوهٌ يَوْمَئِذٍ خَـٰشِعَةٌ","arabic_simple":"","english":"On that day (many) faces will be downcast,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":3,"key":"88:3","arabic_uthmani":"عَامِلَةٌ نَّاصِبَةٌ","arabic_simple":"","english":"Toiling, weary,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":4,"key":"88:4","arabic_uthmani":"تَصْلَىٰ نَارًا حَامِيَةً","arabic_simple":"","english":"Scorched by burning fire,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":5,"key":"88:5","arabic_uthmani":"تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍ","arabic_simple":"","english":"Drinking from a boiling spring,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":6,"key":"88:6","arabic_uthmani":"لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍ","arabic_simple":"","english":"No food for them save bitter thorn-fruit","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":7,"key":"88:7","arabic_uthmani":"لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍ","arabic_simple":"","english":"Which doth not nourish nor release from hunger.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":8,"key":"88:8","arabic_uthmani":"وُجُوهٌ يَوْمَئِذٍ نَّاعِمَةٌ","arabic_simple":"","english":"In that day other faces will be calm,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":9,"key":"88:9","arabic_uthmani":"لِّسَعْيِهَا رَاضِيَةٌ","arabic_simple":"","english":"Glad for their effort past,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":10,"key":"88:10","arabic_uthmani":"فِى جَنَّةٍ عَالِيَةٍ","arabic_simple":"","english":"In a high Garden","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":11,"key":"88:11","arabic_uthmani":"لَّا تَسْمَعُ فِيهَا لَـٰغِيَةً","arabic_simple":"","english":"Where they hear no idle speech,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":12,"key":"88:12","arabic_uthmani":"فِيهَا عَيْنٌ جَارِيَةٌ","arabic_simple":"","english":"Wherein is a gushing spring,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":13,"key":"88:13","arabic_uthmani":"فِيهَا سُرُرٌ مَّرْفُوعَةٌ","arabic_simple":"","english":"Wherein are couches raised","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":14,"key":"88:14","arabic_uthmani":"وَأَكْوَابٌ مَّوْضُوعَةٌ","arabic_simple":"","english":"And goblets set at hand","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":15,"key":"88:15","arabic_uthmani":"وَنَمَارِقُ مَصْفُوفَةٌ","arabic_simple":"","english":"And cushions ranged","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":16,"key":"88:16","arabic_uthmani":"وَزَرَابِىُّ مَبْثُوثَةٌ","arabic_simple":"","english":"And silken carpets spread.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":17,"key":"88:17","arabic_uthmani":"أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ","arabic_simple":"","english":"Will they not regard the camels, how they are created?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":18,"key":"88:18","arabic_uthmani":"وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ","arabic_simple":"","english":"And the heaven, how it is raised?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":19,"key":"88:19","arabic_uthmani":"وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ","arabic_simple":"","english":"And the hills, how they are set up?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":20,"key":"88:20","arabic_uthmani":"وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ","arabic_simple":"","english":"And the earth, how it is spread?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":21,"key":"88:21","arabic_uthmani":"فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌ","arabic_simple":"","english":"Remind them, for thou art but a remembrancer,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":22,"key":"88:22","arabic_uthmani":"لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ","arabic_simple":"","english":"Thou art not at all a warder over them.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":23,"key":"88:23","arabic_uthmani":"إِلَّا مَن تَوَلَّىٰ وَكَفَرَ","arabic_simple":"","english":"But whoso is averse and disbelieveth,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":24,"key":"88:24","arabic_uthmani":"فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ","arabic_simple":"","english":"Allah will punish him with direst punishment.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":25,"key":"88:25","arabic_uthmani":"إِنَّ إِلَيْنَآ إِيَابَهُمْ","arabic_simple":"","english":"Lo! unto Us is their return","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":88,"ayah":26,"key":"88:26","arabic_uthmani":"ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم","arabic_simple":"","english":"And Ours their reckoning.","juz":30,"hizb":0,"ruku":0,"page":0}]}