{"surah":104,"ayat":[{"surah":104,"ayah":1,"key":"104:1","arabic_uthmani":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍ","arabic_simple":"","english":"Woe unto every slandering traducer,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":104,"ayah":2,"key":"104:2","arabic_uthmani":"ٱلَّذِى جَمَعَ مَالًا وَعَدَّدَهُۥ","arabic_simple":"","english":"Who hath gathered wealth (of this world) and arranged it.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":104,"ayah":3,"key":"104:3","arabic_uthmani":"يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ","arabic_simple":"","english":"He thinketh that his wealth will render him immortal.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":104,"ayah":4,"key":"104:4","arabic_uthmani":"كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ","arabic_simple":"","english":"Nay, but verily he will be flung to the Consuming One.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":104,"ayah":5,"key":"104:5","arabic_uthmani":"وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ","arabic_simple":"","english":"Ah, what will convey unto thee what the Consuming One is!","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":104,"ayah":6,"key":"104:6","arabic_uthmani":"نَارُ ٱللَّهِ ٱلْمُوقَدَةُ","arabic_simple":"","english":"(It is) the fire of Allah, kindled,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":104,"ayah":7,"key":"104:7","arabic_uthmani":"ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ","arabic_simple":"","english":"Which leapeth up over the hearts (of men).","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":104,"ayah":8,"key":"104:8","arabic_uthmani":"إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ","arabic_simple":"","english":"Lo! it is closed in on them","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":104,"ayah":9,"key":"104:9","arabic_uthmani":"فِى عَمَدٍ مُّمَدَّدَةٍۭ","arabic_simple":"","english":"In outstretched columns.","juz":30,"hizb":0,"ruku":0,"page":0}]}