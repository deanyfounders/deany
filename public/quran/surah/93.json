{"surah":93,"ayat":[{"surah":93,"ayah":1,"key":"93:1","arabic_uthmani":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلضُّحَىٰ","arabic_simple":"","english":"By the morning hours","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":93,"ayah":2,"key":"93:2","arabic_uthmani":"وَٱلَّيْلِ إِذَا سَجَىٰ","arabic_simple":"","english":"And by the night when it is stillest,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":93,"ayah":3,"key":"93:3","arabic_uthmani":"مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ","arabic_simple":"","english":"Thy Lord hath not forsaken thee nor doth He hate thee,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":93,"ayah":4,"key":"93:4","arabic_uthmani":"وَلَلْـَٔاخِرَةُ خَيْرٌ لَّكَ مِنَ ٱلْأُولَىٰ","arabic_simple":"","english":"And verily the latter portion will be better for thee than the former,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":93,"ayah":5,"key":"93:5","arabic_uthmani":"وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ","arabic_simple":"","english":"And verily thy Lord will give unto thee so that thou wilt be content.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":93,"ayah":6,"key":"93:6","arabic_uthmani":"أَلَمْ يَجِدْكَ يَتِيمًا فَـَٔاوَىٰ","arabic_simple":"","english":"Did He not find thee an orphan and protect (thee)?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":93,"ayah":7,"key":"93:7","arabic_uthmani":"وَوَجَدَكَ ضَآلًّا فَهَدَىٰ","arabic_simple":"","english":"Did He not find thee wandering and direct (thee)?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":93,"ayah":8,"key":"93:8","arabic_uthmani":"وَوَجَدَكَ عَآئِلًا فَأَغْنَىٰ","arabic_simple":"","english":"Did He not find thee destitute and enrich (thee)?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":93,"ayah":9,"key":"93:9","arabic_uthmani":"فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ","arabic_simple":"","english":"Therefor the orphan oppress not,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":93,"ayah":10,"key":"93:10","arabic_uthmani":"وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ","arabic_simple":"","english":"Therefor the beggar drive not away,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":93,"ayah":11,"key":"93:11","arabic_uthmani":"وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ","arabic_simple":"","english":"Therefor of the bounty of thy Lord be thy discourse.","juz":30,"hizb":0,"ruku":0,"page":0}]}