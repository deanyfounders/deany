{"surah":81,"ayat":[{"surah":81,"ayah":1,"key":"81:1","arabic_uthmani":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ إِذَا ٱلشَّمْسُ كُوِّرَتْ","arabic_simple":"","english":"When the sun is overthrown,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":2,"key":"81:2","arabic_uthmani":"وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتْ","arabic_simple":"","english":"And when the stars fall,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":3,"key":"81:3","arabic_uthmani":"وَإِذَا ٱلْجِبَالُ سُيِّرَتْ","arabic_simple":"","english":"And when the hills are moved,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":4,"key":"81:4","arabic_uthmani":"وَإِذَا ٱلْعِشَارُ عُطِّلَتْ","arabic_simple":"","english":"And when the camels big with young are abandoned,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":5,"key":"81:5","arabic_uthmani":"وَإِذَا ٱلْوُحُوشُ حُشِرَتْ","arabic_simple":"","english":"And when the wild beasts are herded together,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":6,"key":"81:6","arabic_uthmani":"وَإِذَا ٱلْبِحَارُ سُجِّرَتْ","arabic_simple":"","english":"And when the seas rise,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":7,"key":"81:7","arabic_uthmani":"وَإِذَا ٱلنُّفُوسُ زُوِّجَتْ","arabic_simple":"","english":"And when souls are reunited,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":8,"key":"81:8","arabic_uthmani":"وَإِذَا ٱلْمَوْءُۥدَةُ سُئِلَتْ","arabic_simple":"","english":"And when the girl-child that was buried alive is asked","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":9,"key":"81:9","arabic_uthmani":"بِأَىِّ ذَنۢبٍ قُتِلَتْ","arabic_simple":"","english":"For what sin she was slain,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":10,"key":"81:10","arabic_uthmani":"وَإِذَا ٱلصُّحُفُ نُشِرَتْ","arabic_simple":"","english":"And when the pages are laid open,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":11,"key":"81:11","arabic_uthmani":"وَإِذَا ٱلسَّمَآءُ كُشِطَتْ","arabic_simple":"","english":"And when the sky is torn away,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":12,"key":"81:12","arabic_uthmani":"وَإِذَا ٱلْجَحِيمُ سُعِّرَتْ","arabic_simple":"","english":"And when hell is lighted,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":13,"key":"81:13","arabic_uthmani":"وَإِذَا ٱلْجَنَّةُ أُزْلِفَتْ","arabic_simple":"","english":"And when the Garden is brought nigh,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":14,"key":"81:14","arabic_uthmani":"عَلِمَتْ نَفْسٌ مَّآ أَحْضَرَتْ","arabic_simple":"","english":"(Then) every soul will know what it hath made ready.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":15,"key":"81:15","arabic_uthmani":"فَلَآ أُقْسِمُ بِٱلْخُنَّسِ","arabic_simple":"","english":"Oh, but I call to witness the planets,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":16,"key":"81:16","arabic_uthmani":"ٱلْجَوَارِ ٱلْكُنَّسِ","arabic_simple":"","english":"The stars which rise and set,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":17,"key":"81:17","arabic_uthmani":"وَٱلَّيْلِ إِذَا عَسْعَسَ","arabic_simple":"","english":"And the close of night,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":18,"key":"81:18","arabic_uthmani":"وَٱلصُّبْحِ إِذَا تَنَفَّسَ","arabic_simple":"","english":"And the breath of morning","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":19,"key":"81:19","arabic_uthmani":"إِنَّهُۥ لَقَوْلُ رَسُولٍ كَرِيمٍ","arabic_simple":"","english":"That this is in truth the word of an honoured messenger,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":20,"key":"81:20","arabic_uthmani":"ذِى قُوَّةٍ عِندَ ذِى ٱلْعَرْشِ مَكِينٍ","arabic_simple":"","english":"Mighty, established in the presence of the Lord of the Throne,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":21,"key":"81:21","arabic_uthmani":"مُّطَاعٍ ثَمَّ أَمِينٍ","arabic_simple":"","english":"(One) to be obeyed, and trustworthy;","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":22,"key":"81:22","arabic_uthmani":"وَمَا صَاحِبُكُم بِمَجْنُونٍ","arabic_simple":"","english":"And your comrade is not mad.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":23,"key":"81:23","arabic_uthmani":"وَلَقَدْ رَءَاهُ بِٱلْأُفُقِ ٱلْمُبِينِ","arabic_simple":"","english":"Surely he beheld Him on the clear horizon.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":24,"key":"81:24","arabic_uthmani":"وَمَا هُوَ عَلَى ٱلْغَيْبِ بِضَنِينٍ","arabic_simple":"","english":"And he is not avid of the Unseen.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":25,"key":"81:25","arabic_uthmani":"وَمَا هُوَ بِقَوْلِ شَيْطَـٰنٍ رَّجِيمٍ","arabic_simple":"","english":"Nor is this the utterance of a devil worthy to be stoned.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":26,"key":"81:26","arabic_uthmani":"فَأَيْنَ تَذْهَبُونَ","arabic_simple":"","english":"Whither then go ye?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":27,"key":"81:27","arabic_uthmani":"إِنْ هُوَ إِلَّا ذِكْرٌ لِّلْعَـٰلَمِينَ","arabic_simple":"","english":"This is naught else than a reminder unto creation,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":28,"key":"81:28","arabic_uthmani":"لِمَن شَآءَ مِنكُمْ أَن يَسْتَقِيمَ","arabic_simple":"","english":"Unto whomsoever of you willeth to walk straight.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":81,"ayah":29,"key":"81:29","arabic_uthmani":"وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ رَبُّ ٱلْعَـٰلَمِينَ","arabic_simple":"","english":"And ye will not, unless (it be) that Allah willeth, the Lord of Creation.","juz":30,"hizb":0,"ruku":0,"page":0}]}