{"surah":87,"ayat":[{"surah":87,"ayah":1,"key":"87:1","arabic_uthmani":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ سَبِّحِ ٱسْمَ رَبِّكَ ٱلْأَعْلَى","arabic_simple":"","english":"Praise the name of thy Lord the Most High,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":87,"ayah":2,"key":"87:2","arabic_uthmani":"ٱلَّذِى خَلَقَ فَسَوَّىٰ","arabic_simple":"","english":"Who createth, then disposeth;","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":87,"ayah":3,"key":"87:3","arabic_uthmani":"وَٱلَّذِى قَدَّرَ فَهَدَىٰ","arabic_simple":"","english":"Who measureth, then guideth;","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":87,"ayah":4,"key":"87:4","arabic_uthmani":"وَٱلَّذِىٓ أَخْرَجَ ٱلْمَرْعَىٰ","arabic_simple":"","english":"Who bringeth forth the pasturage,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":87,"ayah":5,"key":"87:5","arabic_uthmani":"فَجَعَلَهُۥ غُثَآءً أَحْوَىٰ","arabic_simple":"","english":"Then turneth it to russet stubble.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":87,"ayah":6,"key":"87:6","arabic_uthmani":"سَنُقْرِئُكَ فَلَا تَنسَىٰٓ","arabic_simple":"","english":"We shall make thee read (O Muhammad) so that thou shalt not forget","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":87,"ayah":7,"key":"87:7","arabic_uthmani":"إِلَّا مَا شَآءَ ٱللَّهُ ۚ إِنَّهُۥ يَعْلَمُ ٱلْجَهْرَ وَمَا يَخْفَىٰ","arabic_simple":"","english":"Save that which Allah willeth. Lo! He knoweth the disclosed and that which still is hidden;","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":87,"ayah":8,"key":"87:8","arabic_uthmani":"وَنُيَسِّرُكَ لِلْيُسْرَىٰ","arabic_simple":"","english":"And We shall ease thy way unto the state of ease.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":87,"ayah":9,"key":"87:9","arabic_uthmani":"فَذَكِّرْ إِن نَّفَعَتِ ٱلذِّكْرَىٰ","arabic_simple":"","english":"Therefor remind (men), for of use is the reminder.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":87,"ayah":10,"key":"87:10","arabic_uthmani":"سَيَذَّكَّرُ مَن يَخْشَىٰ","arabic_simple":"","english":"He will heed who feareth,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":87,"ayah":11,"key":"87:11","arabic_uthmani":"وَيَتَجَنَّبُهَا ٱلْأَشْقَى","arabic_simple":"","english":"But the most hapless will flout it,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":87,"ayah":12,"key":"87:12","arabic_uthmani":"ٱلَّذِى يَصْلَى ٱلنَّارَ ٱلْكُبْرَىٰ","arabic_simple":"","english":"He who will be flung to the great Fire","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":87,"ayah":13,"key":"87:13","arabic_uthmani":"ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ","arabic_simple":"","english":"Wherein he will neither die nor live.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":87,"ayah":14,"key":"87:14","arabic_uthmani":"قَدْ أَفْلَحَ مَن تَزَكَّىٰ","arabic_simple":"","english":"He is successful who groweth,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":87,"ayah":15,"key":"87:15","arabic_uthmani":"وَذَكَرَ ٱسْمَ رَبِّهِۦ فَصَلَّىٰ","arabic_simple":"","english":"And remembereth the name of his Lord, so prayeth,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":87,"ayah":16,"key":"87:16","arabic_uthmani":"بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا","arabic_simple":"","english":"But ye prefer the life of the world","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":87,"ayah":17,"key":"87:17","arabic_uthmani":"وَٱلْـَٔاخِرَةُ خَيْرٌ وَأَبْقَىٰٓ","arabic_simple":"","english":"Although the Hereafter is better and more lasting.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":87,"ayah":18,"key":"87:18","arabic_uthmani":"إِنَّ هَـٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ","arabic_simple":"","english":"Lo! This is in the former scrolls.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":87,"ayah":19,"key":"87:19","arabic_uthmani":"صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ","arabic_simple":"","english":"The Books of Abraham and Moses.","juz":30,"hizb":0,"ruku":0,"page":0}]}