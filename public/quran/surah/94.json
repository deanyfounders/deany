{"surah":94,"ayat":[{"surah":94,"ayah":1,"key":"94:1","arabic_uthmani":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ","arabic_simple":"","english":"Have We not caused thy bosom to dilate,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":94,"ayah":2,"key":"94:2","arabic_uthmani":"وَوَضَعْنَا عَنكَ وِزْرَكَ","arabic_simple":"","english":"And eased thee of the burden","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":94,"ayah":3,"key":"94:3","arabic_uthmani":"ٱلَّذِىٓ أَنقَضَ ظَهْرَكَ","arabic_simple":"","english":"Which weighed down thy back;","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":94,"ayah":4,"key":"94:4","arabic_uthmani":"وَرَفَعْنَا لَكَ ذِكْرَكَ","arabic_simple":"","english":"And exalted thy fame?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":94,"ayah":5,"key":"94:5","arabic_uthmani":"فَإِنَّ مَعَ ٱلْعُسْرِ يُسْرًا","arabic_simple":"","english":"But lo! with hardship goeth ease,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":94,"ayah":6,"key":"94:6","arabic_uthmani":"إِنَّ مَعَ ٱلْعُسْرِ يُسْرًا","arabic_simple":"","english":"Lo! with hardship goeth ease;","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":94,"ayah":7,"key":"94:7","arabic_uthmani":"فَإِذَا فَرَغْتَ فَٱنصَبْ","arabic_simple":"","english":"So when thou art relieved, still toil","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":94,"ayah":8,"key":"94:8","arabic_uthmani":"وَإِلَىٰ رَبِّكَ فَٱرْغَب","arabic_simple":"","english":"And strive to please thy Lord.","juz":30,"hizb":0,"ruku":0,"page":0}]}