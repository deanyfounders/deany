{"surah":56,"ayat":[{"surah":56,"ayah":1,"key":"56:1","arabic_uthmani":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ إِذَا وَقَعَتِ ٱلْوَاقِعَةُ","arabic_simple":"","english":"When the event befalleth -","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":2,"key":"56:2","arabic_uthmani":"لَيْسَ لِوَقْعَتِهَا كَاذِبَةٌ","arabic_simple":"","english":"There is no denying that it will befall -","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":3,"key":"56:3","arabic_uthmani":"خَافِضَةٌ رَّافِعَةٌ","arabic_simple":"","english":"Abasing (some), exalting (others);","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":4,"key":"56:4","arabic_uthmani":"إِذَا رُجَّتِ ٱلْأَرْضُ رَجًّا","arabic_simple":"","english":"When the earth is shaken with a shock","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":5,"key":"56:5","arabic_uthmani":"وَبُسَّتِ ٱلْجِبَالُ بَسًّا","arabic_simple":"","english":"And the hills are ground to powder","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":6,"key":"56:6","arabic_uthmani":"فَكَانَتْ هَبَآءً مُّنۢبَثًّا","arabic_simple":"","english":"So that they become a scattered dust,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":7,"key":"56:7","arabic_uthmani":"وَكُنتُمْ أَزْوَٰجًا ثَلَـٰثَةً","arabic_simple":"","english":"And ye will be three kinds:","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":8,"key":"56:8","arabic_uthmani":"فَأَصْحَـٰبُ ٱلْمَيْمَنَةِ مَآ أَصْحَـٰبُ ٱلْمَيْمَنَةِ","arabic_simple":"","english":"(First) those on the right hand; what of those on the right hand?","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":9,"key":"56:9","arabic_uthmani":"وَأَصْحَـٰبُ ٱلْمَشْـَٔمَةِ مَآ أَصْحَـٰبُ ٱلْمَشْـَٔمَةِ","arabic_simple":"","english":"And (then) those on the left hand; what of those on the left hand?","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":10,"key":"56:10","arabic_uthmani":"وَٱلسَّـٰبِقُونَ ٱلسَّـٰبِقُونَ","arabic_simple":"","english":"And the foremost in the race, the foremost in the race:","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":11,"key":"56:11","arabic_uthmani":"أُو۟لَـٰٓئِكَ ٱلْمُقَرَّبُونَ","arabic_simple":"","english":"Those are they who will be brought nigh","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":12,"key":"56:12","arabic_uthmani":"فِى جَنَّـٰتِ ٱلنَّعِيمِ","arabic_simple":"","english":"In gardens of delight;","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":13,"key":"56:13","arabic_uthmani":"ثُلَّةٌ مِّنَ ٱلْأَوَّلِينَ","arabic_simple":"","english":"A multitude of those of old","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":14,"key":"56:14","arabic_uthmani":"وَقَلِيلٌ مِّنَ ٱلْـَٔاخِرِينَ","arabic_simple":"","english":"And a few of those of later time.","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":15,"key":"56:15","arabic_uthmani":"عَلَىٰ سُرُرٍ مَّوْضُونَةٍ","arabic_simple":"","english":"On lined couches,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":16,"key":"56:16","arabic_uthmani":"مُّتَّكِـِٔينَ عَلَيْهَا مُتَقَـٰبِلِينَ","arabic_simple":"","english":"Reclining therein face to face.","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":17,"key":"56:17","arabic_uthmani":"يَطُوفُ عَلَيْهِمْ وِلْدَٰنٌ مُّخَلَّدُونَ","arabic_simple":"","english":"There wait on them immortal youths","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":18,"key":"56:18","arabic_uthmani":"بِأَكْوَابٍ وَأَبَارِيقَ وَكَأْسٍ مِّن مَّعِينٍ","arabic_simple":"","english":"With bowls and ewers and a cup from a pure spring","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":19,"key":"56:19","arabic_uthmani":"لَّا يُصَدَّعُونَ عَنْهَا وَلَا يُنزِفُونَ","arabic_simple":"","english":"Wherefrom they get no aching of the head nor any madness,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":20,"key":"56:20","arabic_uthmani":"وَفَـٰكِهَةٍ مِّمَّا يَتَخَيَّرُونَ","arabic_simple":"","english":"And fruit that they prefer","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":21,"key":"56:21","arabic_uthmani":"وَلَحْمِ طَيْرٍ مِّمَّا يَشْتَهُونَ","arabic_simple":"","english":"And flesh of fowls that they desire.","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":22,"key":"56:22","arabic_uthmani":"وَحُورٌ عِينٌ","arabic_simple":"","english":"And (there are) fair ones with wide, lovely eyes,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":23,"key":"56:23","arabic_uthmani":"كَأَمْثَـٰلِ ٱللُّؤْلُؤِ ٱلْمَكْنُونِ","arabic_simple":"","english":"Like unto hidden pearls,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":24,"key":"56:24","arabic_uthmani":"جَزَآءًۢ بِمَا كَانُوا۟ يَعْمَلُونَ","arabic_simple":"","english":"Reward for what they used to do.","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":25,"key":"56:25","arabic_uthmani":"لَا يَسْمَعُونَ فِيهَا لَغْوًا وَلَا تَأْثِيمًا","arabic_simple":"","english":"There hear they no vain speaking nor recrimination","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":26,"key":"56:26","arabic_uthmani":"إِلَّا قِيلًا سَلَـٰمًا سَلَـٰمًا","arabic_simple":"","english":"(Naught) but the saying: Peace, (and again) Peace.","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":27,"key":"56:27","arabic_uthmani":"وَأَصْحَـٰبُ ٱلْيَمِينِ مَآ أَصْحَـٰبُ ٱلْيَمِينِ","arabic_simple":"","english":"And those on the right hand; what of those on the right hand?","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":28,"key":"56:28","arabic_uthmani":"فِى سِدْرٍ مَّخْضُودٍ","arabic_simple":"","english":"Among thornless lote-trees","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":29,"key":"56:29","arabic_uthmani":"وَطَلْحٍ مَّنضُودٍ","arabic_simple":"","english":"And clustered plantains,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":30,"key":"56:30","arabic_uthmani":"وَظِلٍّ مَّمْدُودٍ","arabic_simple":"","english":"And spreading shade,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":31,"key":"56:31","arabic_uthmani":"وَمَآءٍ مَّسْكُوبٍ","arabic_simple":"","english":"And water gushing,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":32,"key":"56:32","arabic_uthmani":"وَفَـٰكِهَةٍ كَثِيرَةٍ","arabic_simple":"","english":"And fruit in plenty","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":33,"key":"56:33","arabic_uthmani":"لَّا مَقْطُوعَةٍ وَلَا مَمْنُوعَةٍ","arabic_simple":"","english":"Neither out of reach nor yet forbidden,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":34,"key":"56:34","arabic_uthmani":"وَفُرُشٍ مَّرْفُوعَةٍ","arabic_simple":"","english":"And raised couches;","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":35,"key":"56:35","arabic_uthmani":"إِنَّآ أَنشَأْنَـٰهُنَّ إِنشَآءً","arabic_simple":"","english":"Lo! We have created them a (new) creation","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":36,"key":"56:36","arabic_uthmani":"فَجَعَلْنَـٰهُنَّ أَبْكَارًا","arabic_simple":"","english":"And made them virgins,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":37,"key":"56:37","arabic_uthmani":"عُرُبًا أَتْرَابًا","arabic_simple":"","english":"Lovers, friends,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":38,"key":"56:38","arabic_uthmani":"لِّأَصْحَـٰبِ ٱلْيَمِينِ","arabic_simple":"","english":"For those on the right hand;","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":39,"key":"56:39","arabic_uthmani":"ثُلَّةٌ مِّنَ ٱلْأَوَّلِينَ","arabic_simple":"","english":"A multitude of those of old","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":40,"key":"56:40","arabic_uthmani":"وَثُلَّةٌ مِّنَ ٱلْـَٔاخِرِينَ","arabic_simple":"","english":"And a multitude of those of later time.","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":41,"key":"56:41","arabic_uthmani":"وَأَصْحَـٰبُ ٱلشِّمَالِ مَآ أَصْحَـٰبُ ٱلشِّمَالِ","arabic_simple":"","english":"And those on the left hand: What of those on the left hand?","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":42,"key":"56:42","arabic_uthmani":"فِى سَمُومٍ وَحَمِيمٍ","arabic_simple":"","english":"In scorching wind and scalding water","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":43,"key":"56:43","arabic_uthmani":"وَظِلٍّ مِّن يَحْمُومٍ","arabic_simple":"","english":"And shadow of black smoke,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":44,"key":"56:44","arabic_uthmani":"لَّا بَارِدٍ وَلَا كَرِيمٍ","arabic_simple":"","english":"Neither cool nor refreshing.","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":45,"key":"56:45","arabic_uthmani":"إِنَّهُمْ كَانُوا۟ قَبْلَ ذَٰلِكَ مُتْرَفِينَ","arabic_simple":"","english":"Lo! heretofore they were effete with luxury","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":46,"key":"56:46","arabic_uthmani":"وَكَانُوا۟ يُصِرُّونَ عَلَى ٱلْحِنثِ ٱلْعَظِيمِ","arabic_simple":"","english":"And used to persist in the awful sin.","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":47,"key":"56:47","arabic_uthmani":"وَكَانُوا۟ يَقُولُونَ أَئِذَا مِتْنَا وَكُنَّا تُرَابًا وَعِظَـٰمًا أَءِنَّا لَمَبْعُوثُونَ","arabic_simple":"","english":"And they used to say: When we are dead and have become dust and bones, shall we then, forsooth, be raised again,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":48,"key":"56:48","arabic_uthmani":"أَوَءَابَآؤُنَا ٱلْأَوَّلُونَ","arabic_simple":"","english":"And also our forefathers?","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":49,"key":"56:49","arabic_uthmani":"قُلْ إِنَّ ٱلْأَوَّلِينَ وَٱلْـَٔاخِرِينَ","arabic_simple":"","english":"Say (unto them, O Muhammad): Lo! those of old and those of later time","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":50,"key":"56:50","arabic_uthmani":"لَمَجْمُوعُونَ إِلَىٰ مِيقَـٰتِ يَوْمٍ مَّعْلُومٍ","arabic_simple":"","english":"Will all be brought together to the tryst of an appointed day.","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":51,"key":"56:51","arabic_uthmani":"ثُمَّ إِنَّكُمْ أَيُّهَا ٱلضَّآلُّونَ ٱلْمُكَذِّبُونَ","arabic_simple":"","english":"Then lo! ye, the erring, the deniers,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":52,"key":"56:52","arabic_uthmani":"لَـَٔاكِلُونَ مِن شَجَرٍ مِّن زَقُّومٍ","arabic_simple":"","english":"Ye verily will eat of a tree called Zaqqum","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":53,"key":"56:53","arabic_uthmani":"فَمَالِـُٔونَ مِنْهَا ٱلْبُطُونَ","arabic_simple":"","english":"And will fill your bellies therewith;","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":54,"key":"56:54","arabic_uthmani":"فَشَـٰرِبُونَ عَلَيْهِ مِنَ ٱلْحَمِيمِ","arabic_simple":"","english":"And thereon ye will drink of boiling water,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":55,"key":"56:55","arabic_uthmani":"فَشَـٰرِبُونَ شُرْبَ ٱلْهِيمِ","arabic_simple":"","english":"Drinking even as the camel drinketh.","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":56,"key":"56:56","arabic_uthmani":"هَـٰذَا نُزُلُهُمْ يَوْمَ ٱلدِّينِ","arabic_simple":"","english":"This will be their welcome on the Day of Judgment.","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":57,"key":"56:57","arabic_uthmani":"نَحْنُ خَلَقْنَـٰكُمْ فَلَوْلَا تُصَدِّقُونَ","arabic_simple":"","english":"We created you. Will ye then admit the truth?","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":58,"key":"56:58","arabic_uthmani":"أَفَرَءَيْتُم مَّا تُمْنُونَ","arabic_simple":"","english":"Have ye seen that which ye emit?","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":59,"key":"56:59","arabic_uthmani":"ءَأَنتُمْ تَخْلُقُونَهُۥٓ أَمْ نَحْنُ ٱلْخَـٰلِقُونَ","arabic_simple":"","english":"Do ye create it or are We the Creator?","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":60,"key":"56:60","arabic_uthmani":"نَحْنُ قَدَّرْنَا بَيْنَكُمُ ٱلْمَوْتَ وَمَا نَحْنُ بِمَسْبُوقِينَ","arabic_simple":"","english":"We mete out death among you, and We are not to be outrun,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":61,"key":"56:61","arabic_uthmani":"عَلَىٰٓ أَن نُّبَدِّلَ أَمْثَـٰلَكُمْ وَنُنشِئَكُمْ فِى مَا لَا تَعْلَمُونَ","arabic_simple":"","english":"That We may transfigure you and make you what ye know not.","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":62,"key":"56:62","arabic_uthmani":"وَلَقَدْ عَلِمْتُمُ ٱلنَّشْأَةَ ٱلْأُولَىٰ فَلَوْلَا تَذَكَّرُونَ","arabic_simple":"","english":"And verily ye know the first creation. Why, then, do ye not reflect?","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":63,"key":"56:63","arabic_uthmani":"أَفَرَءَيْتُم مَّا تَحْرُثُونَ","arabic_simple":"","english":"Have ye seen that which ye cultivate?","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":64,"key":"56:64","arabic_uthmani":"ءَأَنتُمْ تَزْرَعُونَهُۥٓ أَمْ نَحْنُ ٱلزَّٰرِعُونَ","arabic_simple":"","english":"Is it ye who foster it, or are We the Fosterer?","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":65,"key":"56:65","arabic_uthmani":"لَوْ نَشَآءُ لَجَعَلْنَـٰهُ حُطَـٰمًا فَظَلْتُمْ تَفَكَّهُونَ","arabic_simple":"","english":"If We willed, We verily could make it chaff, then would ye cease not to exclaim:","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":66,"key":"56:66","arabic_uthmani":"إِنَّا لَمُغْرَمُونَ","arabic_simple":"","english":"Lo! we are laden with debt!","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":67,"key":"56:67","arabic_uthmani":"بَلْ نَحْنُ مَحْرُومُونَ","arabic_simple":"","english":"Nay, but we are deprived!","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":68,"key":"56:68","arabic_uthmani":"أَفَرَءَيْتُمُ ٱلْمَآءَ ٱلَّذِى تَشْرَبُونَ","arabic_simple":"","english":"Have ye observed the water which ye drink?","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":69,"key":"56:69","arabic_uthmani":"ءَأَنتُمْ أَنزَلْتُمُوهُ مِنَ ٱلْمُزْنِ أَمْ نَحْنُ ٱلْمُنزِلُونَ","arabic_simple":"","english":"Is it ye who shed it from the raincloud, or are We the Shedder?","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":70,"key":"56:70","arabic_uthmani":"لَوْ نَشَآءُ جَعَلْنَـٰهُ أُجَاجًا فَلَوْلَا تَشْكُرُونَ","arabic_simple":"","english":"If We willed We verily could make it bitter. Why then, give ye not thanks?","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":71,"key":"56:71","arabic_uthmani":"أَفَرَءَيْتُمُ ٱلنَّارَ ٱلَّتِى تُورُونَ","arabic_simple":"","english":"Have ye observed the fire which ye strike out;","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":72,"key":"56:72","arabic_uthmani":"ءَأَنتُمْ أَنشَأْتُمْ شَجَرَتَهَآ أَمْ نَحْنُ ٱلْمُنشِـُٔونَ","arabic_simple":"","english":"Was it ye who made the tree thereof to grow, or were We the grower?","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":73,"key":"56:73","arabic_uthmani":"نَحْنُ جَعَلْنَـٰهَا تَذْكِرَةً وَمَتَـٰعًا لِّلْمُقْوِينَ","arabic_simple":"","english":"We, even We, appointed it a memorial and a comfort for the dwellers in the wilderness.","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":74,"key":"56:74","arabic_uthmani":"فَسَبِّحْ بِٱسْمِ رَبِّكَ ٱلْعَظِيمِ","arabic_simple":"","english":"Therefor (O Muhammad), praise the name of thy Lord, the Tremendous.","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":75,"key":"56:75","arabic_uthmani":"۞ فَلَآ أُقْسِمُ بِمَوَٰقِعِ ٱلنُّجُومِ","arabic_simple":"","english":"Nay, I swear by the places of the stars -","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":76,"key":"56:76","arabic_uthmani":"وَإِنَّهُۥ لَقَسَمٌ لَّوْ تَعْلَمُونَ عَظِيمٌ","arabic_simple":"","english":"And lo! that verily is a tremendous oath, if ye but knew -","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":77,"key":"56:77","arabic_uthmani":"إِنَّهُۥ لَقُرْءَانٌ كَرِيمٌ","arabic_simple":"","english":"That (this) is indeed a noble Qur'an","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":78,"key":"56:78","arabic_uthmani":"فِى كِتَـٰبٍ مَّكْنُونٍ","arabic_simple":"","english":"In a Book kept hidden","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":79,"key":"56:79","arabic_uthmani":"لَّا يَمَسُّهُۥٓ إِلَّا ٱلْمُطَهَّرُونَ","arabic_simple":"","english":"Which none toucheth save the purified,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":80,"key":"56:80","arabic_uthmani":"تَنزِيلٌ مِّن رَّبِّ ٱلْعَـٰلَمِينَ","arabic_simple":"","english":"A revelation from the Lord of the Worlds.","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":81,"key":"56:81","arabic_uthmani":"أَفَبِهَـٰذَا ٱلْحَدِيثِ أَنتُم مُّدْهِنُونَ","arabic_simple":"","english":"Is it this Statement that ye scorn,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":82,"key":"56:82","arabic_uthmani":"وَتَجْعَلُونَ رِزْقَكُمْ أَنَّكُمْ تُكَذِّبُونَ","arabic_simple":"","english":"And make denial thereof your livelihood?","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":83,"key":"56:83","arabic_uthmani":"فَلَوْلَآ إِذَا بَلَغَتِ ٱلْحُلْقُومَ","arabic_simple":"","english":"Why, then, when (the soul) cometh up to the throat (of the dying)","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":84,"key":"56:84","arabic_uthmani":"وَأَنتُمْ حِينَئِذٍ تَنظُرُونَ","arabic_simple":"","english":"And ye are at that moment looking","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":85,"key":"56:85","arabic_uthmani":"وَنَحْنُ أَقْرَبُ إِلَيْهِ مِنكُمْ وَلَـٰكِن لَّا تُبْصِرُونَ","arabic_simple":"","english":"- And We are nearer unto him than ye are, but ye see not -","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":86,"key":"56:86","arabic_uthmani":"فَلَوْلَآ إِن كُنتُمْ غَيْرَ مَدِينِينَ","arabic_simple":"","english":"Why then, if ye are not in bondage (unto Us),","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":87,"key":"56:87","arabic_uthmani":"تَرْجِعُونَهَآ إِن كُنتُمْ صَـٰدِقِينَ","arabic_simple":"","english":"Do ye not force it back, if ye are truthful?","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":88,"key":"56:88","arabic_uthmani":"فَأَمَّآ إِن كَانَ مِنَ ٱلْمُقَرَّبِينَ","arabic_simple":"","english":"Thus if he is of those brought nigh,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":89,"key":"56:89","arabic_uthmani":"فَرَوْحٌ وَرَيْحَانٌ وَجَنَّتُ نَعِيمٍ","arabic_simple":"","english":"Then breath of life, and plenty, and a Garden of delight.","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":90,"key":"56:90","arabic_uthmani":"وَأَمَّآ إِن كَانَ مِنْ أَصْحَـٰبِ ٱلْيَمِينِ","arabic_simple":"","english":"And if he is of those on the right hand,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":91,"key":"56:91","arabic_uthmani":"فَسَلَـٰمٌ لَّكَ مِنْ أَصْحَـٰبِ ٱلْيَمِينِ","arabic_simple":"","english":"Then (the greeting) \"Peace be unto thee\" from those on the right hand.","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":92,"key":"56:92","arabic_uthmani":"وَأَمَّآ إِن كَانَ مِنَ ٱلْمُكَذِّبِينَ ٱلضَّآلِّينَ","arabic_simple":"","english":"But if he is of the rejecters, the erring,","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":93,"key":"56:93","arabic_uthmani":"فَنُزُلٌ مِّنْ حَمِيمٍ","arabic_simple":"","english":"Then the welcome will be boiling water","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":94,"key":"56:94","arabic_uthmani":"وَتَصْلِيَةُ جَحِيمٍ","arabic_simple":"","english":"And roasting at hell-fire.","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":95,"key":"56:95","arabic_uthmani":"إِنَّ هَـٰذَا لَهُوَ حَقُّ ٱلْيَقِينِ","arabic_simple":"","english":"Lo! this is certain truth.","juz":27,"hizb":0,"ruku":0,"page":0},{"surah":56,"ayah":96,"key":"56:96","arabic_uthmani":"فَسَبِّحْ بِٱسْمِ رَبِّكَ ٱلْعَظِيمِ","arabic_simple":"","english":"Therefor (O Muhammad) praise the name of thy Lord, the Tremendous.","juz":27,"hizb":0,"ruku":0,"page":0}]}