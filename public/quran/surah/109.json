{"surah":109,"ayat":[{"surah":109,"ayah":1,"key":"109:1","arabic_uthmani":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ قُلْ يَـٰٓأَيُّهَا ٱلْكَـٰفِرُونَ","arabic_simple":"","english":"Say: O disbelievers!","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":109,"ayah":2,"key":"109:2","arabic_uthmani":"لَآ أَعْبُدُ مَا تَعْبُدُونَ","arabic_simple":"","english":"I worship not that which ye worship;","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":109,"ayah":3,"key":"109:3","arabic_uthmani":"وَلَآ أَنتُمْ عَـٰبِدُونَ مَآ أَعْبُدُ","arabic_simple":"","english":"Nor worship ye that which I worship.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":109,"ayah":4,"key":"109:4","arabic_uthmani":"وَلَآ أَنَا۠ عَابِدٌ مَّا عَبَدتُّمْ","arabic_simple":"","english":"And I shall not worship that which ye worship.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":109,"ayah":5,"key":"109:5","arabic_uthmani":"وَلَآ أَنتُمْ عَـٰبِدُونَ مَآ أَعْبُدُ","arabic_simple":"","english":"Nor will ye worship that which I worship.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":109,"ayah":6,"key":"109:6","arabic_uthmani":"لَكُمْ دِينُكُمْ وَلِىَ دِينِ","arabic_simple":"","english":"Unto you your religion, and unto me my religion.","juz":30,"hizb":0,"ruku":0,"page":0}]}