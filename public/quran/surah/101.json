{"surah":101,"ayat":[{"surah":101,"ayah":1,"key":"101:1","arabic_uthmani":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ ٱلْقَارِعَةُ","arabic_simple":"","english":"The Calamity!","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":101,"ayah":2,"key":"101:2","arabic_uthmani":"مَا ٱلْقَارِعَةُ","arabic_simple":"","english":"What is the Calamity?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":101,"ayah":3,"key":"101:3","arabic_uthmani":"وَمَآ أَدْرَىٰكَ مَا ٱلْقَارِعَةُ","arabic_simple":"","english":"Ah, what will convey unto thee what the Calamity is!","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":101,"ayah":4,"key":"101:4","arabic_uthmani":"يَوْمَ يَكُونُ ٱلنَّاسُ كَٱلْفَرَاشِ ٱلْمَبْثُوثِ","arabic_simple":"","english":"A day wherein mankind will be as thickly-scattered moths","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":101,"ayah":5,"key":"101:5","arabic_uthmani":"وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ ٱلْمَنفُوشِ","arabic_simple":"","english":"And the mountains will become as carded wool.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":101,"ayah":6,"key":"101:6","arabic_uthmani":"فَأَمَّا مَن ثَقُلَتْ مَوَٰزِينُهُۥ","arabic_simple":"","english":"Then, as for him whose scales are heavy (with good works),","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":101,"ayah":7,"key":"101:7","arabic_uthmani":"فَهُوَ فِى عِيشَةٍ رَّاضِيَةٍ","arabic_simple":"","english":"He will live a pleasant life.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":101,"ayah":8,"key":"101:8","arabic_uthmani":"وَأَمَّا مَنْ خَفَّتْ مَوَٰزِينُهُۥ","arabic_simple":"","english":"But as for him whose scales are light,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":101,"ayah":9,"key":"101:9","arabic_uthmani":"فَأُمُّهُۥ هَاوِيَةٌ","arabic_simple":"","english":"A bereft and Hungry One will be his mother,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":101,"ayah":10,"key":"101:10","arabic_uthmani":"وَمَآ أَدْرَىٰكَ مَا هِيَهْ","arabic_simple":"","english":"Ah, what will convey unto thee what she is! -","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":101,"ayah":11,"key":"101:11","arabic_uthmani":"نَارٌ حَامِيَةٌۢ","arabic_simple":"","english":"Raging Fire.","juz":30,"hizb":0,"ruku":0,"page":0}]}