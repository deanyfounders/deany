{"surah":102,"ayat":[{"surah":102,"ayah":1,"key":"102:1","arabic_uthmani":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ أَلْهَىٰكُمُ ٱلتَّكَاثُرُ","arabic_simple":"","english":"Rivalry in worldly increase distracteth you","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":102,"ayah":2,"key":"102:2","arabic_uthmani":"حَتَّىٰ زُرْتُمُ ٱلْمَقَابِرَ","arabic_simple":"","english":"Until ye come to the graves.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":102,"ayah":3,"key":"102:3","arabic_uthmani":"كَلَّا سَوْفَ تَعْلَمُونَ","arabic_simple":"","english":"Nay, but ye will come to know!","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":102,"ayah":4,"key":"102:4","arabic_uthmani":"ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ","arabic_simple":"","english":"Nay, but ye will come to know!","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":102,"ayah":5,"key":"102:5","arabic_uthmani":"كَلَّا لَوْ تَعْلَمُونَ عِلْمَ ٱلْيَقِينِ","arabic_simple":"","english":"Nay, would that ye knew (now) with a sure knowledge!","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":102,"ayah":6,"key":"102:6","arabic_uthmani":"لَتَرَوُنَّ ٱلْجَحِيمَ","arabic_simple":"","english":"For ye will behold hell-fire.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":102,"ayah":7,"key":"102:7","arabic_uthmani":"ثُمَّ لَتَرَوُنَّهَا عَيْنَ ٱلْيَقِينِ","arabic_simple":"","english":"Aye, ye will behold it with sure vision.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":102,"ayah":8,"key":"102:8","arabic_uthmani":"ثُمَّ لَتُسْـَٔلُنَّ يَوْمَئِذٍ عَنِ ٱلنَّعِيمِ","arabic_simple":"","english":"Then, on that day, ye will be asked concerning pleasure.","juz":30,"hizb":0,"ruku":0,"page":0}]}