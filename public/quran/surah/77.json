{"surah":77,"ayat":[{"surah":77,"ayah":1,"key":"77:1","arabic_uthmani":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلْمُرْسَلَـٰتِ عُرْفًا","arabic_simple":"","english":"By the emissary winds, (sent) one after another","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":2,"key":"77:2","arabic_uthmani":"فَٱلْعَـٰصِفَـٰتِ عَصْفًا","arabic_simple":"","english":"By the raging hurricanes,","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":3,"key":"77:3","arabic_uthmani":"وَٱلنَّـٰشِرَٰتِ نَشْرًا","arabic_simple":"","english":"By those which cause earth's vegetation to revive;","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":4,"key":"77:4","arabic_uthmani":"فَٱلْفَـٰرِقَـٰتِ فَرْقًا","arabic_simple":"","english":"By those who winnow with a winnowing,","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":5,"key":"77:5","arabic_uthmani":"فَٱلْمُلْقِيَـٰتِ ذِكْرًا","arabic_simple":"","english":"By those who bring down the Reminder,","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":6,"key":"77:6","arabic_uthmani":"عُذْرًا أَوْ نُذْرًا","arabic_simple":"","english":"To excuse or to warn,","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":7,"key":"77:7","arabic_uthmani":"إِنَّمَا تُوعَدُونَ لَوَٰقِعٌ","arabic_simple":"","english":"Surely that which ye are promised will befall.","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":8,"key":"77:8","arabic_uthmani":"فَإِذَا ٱلنُّجُومُ طُمِسَتْ","arabic_simple":"","english":"So when the stars are put out,","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":9,"key":"77:9","arabic_uthmani":"وَإِذَا ٱلسَّمَآءُ فُرِجَتْ","arabic_simple":"","english":"And when the sky is riven asunder,","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":10,"key":"77:10","arabic_uthmani":"وَإِذَا ٱلْجِبَالُ نُسِفَتْ","arabic_simple":"","english":"And when the mountains are blown away,","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":11,"key":"77:11","arabic_uthmani":"وَإِذَا ٱلرُّسُلُ أُقِّتَتْ","arabic_simple":"","english":"And when the messengers are brought unto their time appointed -","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":12,"key":"77:12","arabic_uthmani":"لِأَىِّ يَوْمٍ أُجِّلَتْ","arabic_simple":"","english":"For what day is the time appointed?","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":13,"key":"77:13","arabic_uthmani":"لِيَوْمِ ٱلْفَصْلِ","arabic_simple":"","english":"For the Day of Decision.","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":14,"key":"77:14","arabic_uthmani":"وَمَآ أَدْرَىٰكَ مَا يَوْمُ ٱلْفَصْلِ","arabic_simple":"","english":"And what will convey unto thee what the Day of Decision is! -","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":15,"key":"77:15","arabic_uthmani":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ","arabic_simple":"","english":"Woe unto the repudiators on that day!","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":16,"key":"77:16","arabic_uthmani":"أَلَمْ نُهْلِكِ ٱلْأَوَّلِينَ","arabic_simple":"","english":"Destroyed We not the former folk,","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":17,"key":"77:17","arabic_uthmani":"ثُمَّ نُتْبِعُهُمُ ٱلْـَٔاخِرِينَ","arabic_simple":"","english":"Then caused the latter folk to follow after?","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":18,"key":"77:18","arabic_uthmani":"كَذَٰلِكَ نَفْعَلُ بِٱلْمُجْرِمِينَ","arabic_simple":"","english":"Thus deal We ever with the guilty.","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":19,"key":"77:19","arabic_uthmani":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ","arabic_simple":"","english":"Woe unto the repudiators on that day!","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":20,"key":"77:20","arabic_uthmani":"أَلَمْ نَخْلُقكُّم مِّن مَّآءٍ مَّهِينٍ","arabic_simple":"","english":"Did We not create you from a base fluid","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":21,"key":"77:21","arabic_uthmani":"فَجَعَلْنَـٰهُ فِى قَرَارٍ مَّكِينٍ","arabic_simple":"","english":"Which We laid up in a safe abode","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":22,"key":"77:22","arabic_uthmani":"إِلَىٰ قَدَرٍ مَّعْلُومٍ","arabic_simple":"","english":"For a known term?","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":23,"key":"77:23","arabic_uthmani":"فَقَدَرْنَا فَنِعْمَ ٱلْقَـٰدِرُونَ","arabic_simple":"","english":"Thus We arranged. How excellent is Our arranging!","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":24,"key":"77:24","arabic_uthmani":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ","arabic_simple":"","english":"Woe unto the repudiators on that day!","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":25,"key":"77:25","arabic_uthmani":"أَلَمْ نَجْعَلِ ٱلْأَرْضَ كِفَاتًا","arabic_simple":"","english":"Have We not made the earth a receptacle","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":26,"key":"77:26","arabic_uthmani":"أَحْيَآءً وَأَمْوَٰتًا","arabic_simple":"","english":"Both for the living and the dead,","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":27,"key":"77:27","arabic_uthmani":"وَجَعَلْنَا فِيهَا رَوَٰسِىَ شَـٰمِخَـٰتٍ وَأَسْقَيْنَـٰكُم مَّآءً فُرَاتًا","arabic_simple":"","english":"And placed therein high mountains and given you to drink sweet water therein?","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":28,"key":"77:28","arabic_uthmani":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ","arabic_simple":"","english":"Woe unto the repudiators on that day!","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":29,"key":"77:29","arabic_uthmani":"ٱنطَلِقُوٓا۟ إِلَىٰ مَا كُنتُم بِهِۦ تُكَذِّبُونَ","arabic_simple":"","english":"(It will be said unto them:) Depart unto that (doom) which ye used to deny;","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":30,"key":"77:30","arabic_uthmani":"ٱنطَلِقُوٓا۟ إِلَىٰ ظِلٍّ ذِى ثَلَـٰثِ شُعَبٍ","arabic_simple":"","english":"Depart unto the shadow falling threefold,","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":31,"key":"77:31","arabic_uthmani":"لَّا ظَلِيلٍ وَلَا يُغْنِى مِنَ ٱللَّهَبِ","arabic_simple":"","english":"(Which yet is) no relief nor shelter from the flame.","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":32,"key":"77:32","arabic_uthmani":"إِنَّهَا تَرْمِى بِشَرَرٍ كَٱلْقَصْرِ","arabic_simple":"","english":"Lo! it throweth up sparks like the castles,","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":33,"key":"77:33","arabic_uthmani":"كَأَنَّهُۥ جِمَـٰلَتٌ صُفْرٌ","arabic_simple":"","english":"(Or) as it might be camels of bright yellow hue.","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":34,"key":"77:34","arabic_uthmani":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ","arabic_simple":"","english":"Woe unto the repudiators on that day!","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":35,"key":"77:35","arabic_uthmani":"هَـٰذَا يَوْمُ لَا يَنطِقُونَ","arabic_simple":"","english":"This is a day wherein they speak not,","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":36,"key":"77:36","arabic_uthmani":"وَلَا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ","arabic_simple":"","english":"Nor are they suffered to put forth excuses.","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":37,"key":"77:37","arabic_uthmani":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ","arabic_simple":"","english":"Woe unto the repudiators on that day!","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":38,"key":"77:38","arabic_uthmani":"هَـٰذَا يَوْمُ ٱلْفَصْلِ ۖ جَمَعْنَـٰكُمْ وَٱلْأَوَّلِينَ","arabic_simple":"","english":"This is the Day of Decision, We have brought you and the men of old together.","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":39,"key":"77:39","arabic_uthmani":"فَإِن كَانَ لَكُمْ كَيْدٌ فَكِيدُونِ","arabic_simple":"","english":"If now ye have any wit, outwit Me.","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":40,"key":"77:40","arabic_uthmani":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ","arabic_simple":"","english":"Woe unto the repudiators on that day!","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":41,"key":"77:41","arabic_uthmani":"إِنَّ ٱلْمُتَّقِينَ فِى ظِلَـٰلٍ وَعُيُونٍ","arabic_simple":"","english":"Lo! those who kept their duty are amid shade and fountains,","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":42,"key":"77:42","arabic_uthmani":"وَفَوَٰكِهَ مِمَّا يَشْتَهُونَ","arabic_simple":"","english":"And fruits such as they desire.","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":43,"key":"77:43","arabic_uthmani":"كُلُوا۟ وَٱشْرَبُوا۟ هَنِيٓـًٔۢا بِمَا كُنتُمْ تَعْمَلُونَ","arabic_simple":"","english":"(Unto them it is said:) Eat, drink and welcome, O ye blessed, in return for what ye did.","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":44,"key":"77:44","arabic_uthmani":"إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ","arabic_simple":"","english":"Thus do We reward the good.","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":45,"key":"77:45","arabic_uthmani":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ","arabic_simple":"","english":"Woe unto the repudiators on that day!","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":46,"key":"77:46","arabic_uthmani":"كُلُوا۟ وَتَمَتَّعُوا۟ قَلِيلًا إِنَّكُم مُّجْرِمُونَ","arabic_simple":"","english":"Eat and take your ease (on earth) a little. Lo! ye are guilty.","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":47,"key":"77:47","arabic_uthmani":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ","arabic_simple":"","english":"Woe unto the repudiators on that day!","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":48,"key":"77:48","arabic_uthmani":"وَإِذَا قِيلَ لَهُمُ ٱرْكَعُوا۟ لَا يَرْكَعُونَ","arabic_simple":"","english":"When it is said unto them: Bow down, they bow not down!","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":49,"key":"77:49","arabic_uthmani":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ","arabic_simple":"","english":"Woe unto the repudiators on that day!","juz":29,"hizb":0,"ruku":0,"page":0},{"surah":77,"ayah":50,"key":"77:50","arabic_uthmani":"فَبِأَىِّ حَدِيثٍۭ بَعْدَهُۥ يُؤْمِنُونَ","arabic_simple":"","english":"In what statement, after this, will they believe?","juz":29,"hizb":0,"ruku":0,"page":0}]}