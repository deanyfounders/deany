{"surah":79,"ayat":[{"surah":79,"ayah":1,"key":"79:1","arabic_uthmani":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلنَّـٰزِعَـٰتِ غَرْقًا","arabic_simple":"","english":"By those who drag forth to destruction,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":2,"key":"79:2","arabic_uthmani":"وَٱلنَّـٰشِطَـٰتِ نَشْطًا","arabic_simple":"","english":"By the meteors rushing,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":3,"key":"79:3","arabic_uthmani":"وَٱلسَّـٰبِحَـٰتِ سَبْحًا","arabic_simple":"","english":"By the lone stars floating,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":4,"key":"79:4","arabic_uthmani":"فَٱلسَّـٰبِقَـٰتِ سَبْقًا","arabic_simple":"","english":"By the angels hastening,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":5,"key":"79:5","arabic_uthmani":"فَٱلْمُدَبِّرَٰتِ أَمْرًا","arabic_simple":"","english":"And those who govern the event,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":6,"key":"79:6","arabic_uthmani":"يَوْمَ تَرْجُفُ ٱلرَّاجِفَةُ","arabic_simple":"","english":"On the day when the first trump resoundeth.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":7,"key":"79:7","arabic_uthmani":"تَتْبَعُهَا ٱلرَّادِفَةُ","arabic_simple":"","english":"And the second followeth it,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":8,"key":"79:8","arabic_uthmani":"قُلُوبٌ يَوْمَئِذٍ وَاجِفَةٌ","arabic_simple":"","english":"On that day hearts beat painfully","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":9,"key":"79:9","arabic_uthmani":"أَبْصَـٰرُهَا خَـٰشِعَةٌ","arabic_simple":"","english":"While eyes are downcast","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":10,"key":"79:10","arabic_uthmani":"يَقُولُونَ أَءِنَّا لَمَرْدُودُونَ فِى ٱلْحَافِرَةِ","arabic_simple":"","english":"(Now) they are saying: Shall we really be restored to our first state","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":11,"key":"79:11","arabic_uthmani":"أَءِذَا كُنَّا عِظَـٰمًا نَّخِرَةً","arabic_simple":"","english":"Even after we are crumbled bones?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":12,"key":"79:12","arabic_uthmani":"قَالُوا۟ تِلْكَ إِذًا كَرَّةٌ خَاسِرَةٌ","arabic_simple":"","english":"They say: Then that would be a vain proceeding.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":13,"key":"79:13","arabic_uthmani":"فَإِنَّمَا هِىَ زَجْرَةٌ وَٰحِدَةٌ","arabic_simple":"","english":"Surely it will need but one shout,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":14,"key":"79:14","arabic_uthmani":"فَإِذَا هُم بِٱلسَّاهِرَةِ","arabic_simple":"","english":"And lo! they will be awakened.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":15,"key":"79:15","arabic_uthmani":"هَلْ أَتَىٰكَ حَدِيثُ مُوسَىٰٓ","arabic_simple":"","english":"Hath there come unto thee the history of Moses?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":16,"key":"79:16","arabic_uthmani":"إِذْ نَادَىٰهُ رَبُّهُۥ بِٱلْوَادِ ٱلْمُقَدَّسِ طُوًى","arabic_simple":"","english":"How his Lord called him in the holy vale of Tuwa,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":17,"key":"79:17","arabic_uthmani":"ٱذْهَبْ إِلَىٰ فِرْعَوْنَ إِنَّهُۥ طَغَىٰ","arabic_simple":"","english":"(Saying:) Go thou unto Pharaoh - Lo! he hath rebelled -","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":18,"key":"79:18","arabic_uthmani":"فَقُلْ هَل لَّكَ إِلَىٰٓ أَن تَزَكَّىٰ","arabic_simple":"","english":"And say (unto him): Hast thou (will) to grow (in grace)?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":19,"key":"79:19","arabic_uthmani":"وَأَهْدِيَكَ إِلَىٰ رَبِّكَ فَتَخْشَىٰ","arabic_simple":"","english":"Then I will guide thee to thy Lord and thou shalt fear (Him).","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":20,"key":"79:20","arabic_uthmani":"فَأَرَىٰهُ ٱلْـَٔايَةَ ٱلْكُبْرَىٰ","arabic_simple":"","english":"And he showed him the tremendous token.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":21,"key":"79:21","arabic_uthmani":"فَكَذَّبَ وَعَصَىٰ","arabic_simple":"","english":"But he denied and disobeyed,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":22,"key":"79:22","arabic_uthmani":"ثُمَّ أَدْبَرَ يَسْعَىٰ","arabic_simple":"","english":"Then turned he away in haste,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":23,"key":"79:23","arabic_uthmani":"فَحَشَرَ فَنَادَىٰ","arabic_simple":"","english":"Then gathered he and summoned","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":24,"key":"79:24","arabic_uthmani":"فَقَالَ أَنَا۠ رَبُّكُمُ ٱلْأَعْلَىٰ","arabic_simple":"","english":"And proclaimed: \"I (Pharaoh) am your Lord the Highest.\"","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":25,"key":"79:25","arabic_uthmani":"فَأَخَذَهُ ٱللَّهُ نَكَالَ ٱلْـَٔاخِرَةِ وَٱلْأُولَىٰٓ","arabic_simple":"","english":"So Allah seized him (and made him) an example for the after (life) and for the former.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":26,"key":"79:26","arabic_uthmani":"إِنَّ فِى ذَٰلِكَ لَعِبْرَةً لِّمَن يَخْشَىٰٓ","arabic_simple":"","english":"Lo! herein is indeed a lesson for him who feareth.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":27,"key":"79:27","arabic_uthmani":"ءَأَنتُمْ أَشَدُّ خَلْقًا أَمِ ٱلسَّمَآءُ ۚ بَنَىٰهَا","arabic_simple":"","english":"Are ye the harder to create, or is the heaven that He built?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":28,"key":"79:28","arabic_uthmani":"رَفَعَ سَمْكَهَا فَسَوَّىٰهَا","arabic_simple":"","english":"He raised the height thereof and ordered it;","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":29,"key":"79:29","arabic_uthmani":"وَأَغْطَشَ لَيْلَهَا وَأَخْرَجَ ضُحَىٰهَا","arabic_simple":"","english":"And He made dark the night thereof, and He brought forth the morn thereof.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":30,"key":"79:30","arabic_uthmani":"وَٱلْأَرْضَ بَعْدَ ذَٰلِكَ دَحَىٰهَآ","arabic_simple":"","english":"And after that He spread the earth,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":31,"key":"79:31","arabic_uthmani":"أَخْرَجَ مِنْهَا مَآءَهَا وَمَرْعَىٰهَا","arabic_simple":"","english":"And produced therefrom the water thereof and the pasture thereof,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":32,"key":"79:32","arabic_uthmani":"وَٱلْجِبَالَ أَرْسَىٰهَا","arabic_simple":"","english":"And He made fast the hills,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":33,"key":"79:33","arabic_uthmani":"مَتَـٰعًا لَّكُمْ وَلِأَنْعَـٰمِكُمْ","arabic_simple":"","english":"A provision for you and for your cattle.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":34,"key":"79:34","arabic_uthmani":"فَإِذَا جَآءَتِ ٱلطَّآمَّةُ ٱلْكُبْرَىٰ","arabic_simple":"","english":"But when the great disaster cometh,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":35,"key":"79:35","arabic_uthmani":"يَوْمَ يَتَذَكَّرُ ٱلْإِنسَـٰنُ مَا سَعَىٰ","arabic_simple":"","english":"The day when man will call to mind his (whole) endeavour,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":36,"key":"79:36","arabic_uthmani":"وَبُرِّزَتِ ٱلْجَحِيمُ لِمَن يَرَىٰ","arabic_simple":"","english":"And hell will stand forth visible to him who seeth,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":37,"key":"79:37","arabic_uthmani":"فَأَمَّا مَن طَغَىٰ","arabic_simple":"","english":"Then, as for him who rebelled","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":38,"key":"79:38","arabic_uthmani":"وَءَاثَرَ ٱلْحَيَوٰةَ ٱلدُّنْيَا","arabic_simple":"","english":"And chose the life of the world,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":39,"key":"79:39","arabic_uthmani":"فَإِنَّ ٱلْجَحِيمَ هِىَ ٱلْمَأْوَىٰ","arabic_simple":"","english":"Lo! hell will be his home.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":40,"key":"79:40","arabic_uthmani":"وَأَمَّا مَنْ خَافَ مَقَامَ رَبِّهِۦ وَنَهَى ٱلنَّفْسَ عَنِ ٱلْهَوَىٰ","arabic_simple":"","english":"But as for him who feared to stand before his Lord and restrained his soul from lust,","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":41,"key":"79:41","arabic_uthmani":"فَإِنَّ ٱلْجَنَّةَ هِىَ ٱلْمَأْوَىٰ","arabic_simple":"","english":"Lo! the Garden will be his home.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":42,"key":"79:42","arabic_uthmani":"يَسْـَٔلُونَكَ عَنِ ٱلسَّاعَةِ أَيَّانَ مُرْسَىٰهَا","arabic_simple":"","english":"They ask thee of the Hour: when will it come to port?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":43,"key":"79:43","arabic_uthmani":"فِيمَ أَنتَ مِن ذِكْرَىٰهَآ","arabic_simple":"","english":"Why (ask they)? What hast thou to tell thereof?","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":44,"key":"79:44","arabic_uthmani":"إِلَىٰ رَبِّكَ مُنتَهَىٰهَآ","arabic_simple":"","english":"Unto thy Lord belongeth (knowledge of) the term thereof.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":45,"key":"79:45","arabic_uthmani":"إِنَّمَآ أَنتَ مُنذِرُ مَن يَخْشَىٰهَا","arabic_simple":"","english":"Thou art but a warner unto him who feareth it.","juz":30,"hizb":0,"ruku":0,"page":0},{"surah":79,"ayah":46,"key":"79:46","arabic_uthmani":"كَأَنَّهُمْ يَوْمَ يَرَوْنَهَا لَمْ يَلْبَثُوٓا۟ إِلَّا عَشِيَّةً أَوْ ضُحَىٰهَا","arabic_simple":"","english":"On the day when they behold it, it will be as if they had but tarried for an evening or the morn thereof.","juz":30,"hizb":0,"ruku":0,"page":0}]}